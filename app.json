{
  "expo": {
    "name": "choplocal",
    "slug": "choplocal",
    "version": "1.2.0",
    "runtimeVersion": "sdkVersion",
    "orientation": "portrait",
    "icon": "assets/images/logo.png",
    "scheme": "choplocal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "buildNumber": "22",
      "bundleIdentifier": "com.choplocal.choplocal",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app may use the camera to enable features such as capturing photos or scanning content when available."
      },
      "googleServicesFile": "./assets/GoogleService-Info.plist",
      "entitlements": {
        "aps-environment": "development"
      },
       "associatedDomains": [
        "applinks:app.choplocally.com",
        "applinks:choplocal-alternate.app.link",
        "applinks:choplocally.com"
      ]
    },
    "android": {
      "versionCode": 26,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.choplocal",
      "usesClearTextTraffic": true,
      "useNextNotificationsApi": true,
      "googleServicesFile": "./assets/google-services.json",
      "config": {
        "googleFirebaseMessaging": {
          "defaultNotificationChannelId": "default"
        }
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.choplocally.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "choplocal-alternate.app.link",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "choplocally.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "choplocal",
              "host": "*"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "./plugins/withSentryAuthToken",
      "./plugins/withAndroidSigning",
      [
        "expo-notifications",
        {
          "icon": "assets/images/logo.png",
          "color": "#ffffff",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-build-properties",
      "./plugins/withAndroidTheme",
      "./plugins/fix-firebase-podspec",
      "./plugins/withFirebaseMessaging",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "@react-native-community/datetimepicker",
      "expo-image",
      [
        "@config-plugins/react-native-branch",
        {
          "apiKey": "key_live_hBAF2wCyWQC57K2dSS7pLmjfyAfnqpOb",
          "iosUniversalLinkDomains": [
            "app.choplocally.com",
            "choplocal-alternate.app.link",
            "choplocally.com"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "packagerOpts": {
      "sourceExts": [
        "js",
        "jsx",
        "svgx"
      ],
      "transformer": "node_modules/react-native-svg-transformer/index.js"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5163469b-a7c7-4433-9e65-0f5d86283be2"
      }
    },
    "owner": "xipe",
    "updates": {
      "url": "https://u.expo.dev/5163469b-a7c7-4433-9e65-0f5d86283be2"
    }
  }
}
